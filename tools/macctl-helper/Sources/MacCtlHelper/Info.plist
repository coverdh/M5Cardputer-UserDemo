<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleIdentifier</key>
    <string>dev.cardputer.advctl</string>
    <key>CFBundleExecutable</key>
    <string>ADVCtl</string>
    <key>CFBundleName</key>
    <string>ADVCtl</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>NSBluetoothAlwaysUsageDescription</key>
    <string>ADVCtl connects to the Cardputer ADV over Bluetooth to receive control events.</string>
    <key>NSInputMonitoringUsageDescription</key>
    <string>ADVCtl listens to the Cardputer ADV HID control endpoint for knob commands.</string>
    <key>NSMicrophoneUsageDescription</key>
    <string>ADVCtl requests microphone permission during setup so macOS records the same stable app identity used by the ADV audio bridge.</string>
    <key>NSLocalNetworkUsageDescription</key>
    <string>ADVCtl scans your local network for Apple TV so it can pair and control HomePod/Apple TV volume.</string>
    <key>NSBonjourServices</key>
    <array>
        <string>_airplay._tcp</string>
        <string>_raop._tcp</string>
        <string>_companion-link._tcp</string>
    </array>
    <key>LSUIElement</key>
    <true/>
</dict>
</plist>
